---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CONTACT | Haru Torisawa">
  <div class="contact-container">
    <h1>CONTACT</h1>

    <!-- 取得したFormspreeのURLを設定しました -->
    <form action="https://formspree.io/f/mrejjjyb" method="POST" class="contact-form">
      
      <div class="form-group">
        <label for="name">お名前 / Name</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div class="form-group">
        <label for="email">メールアドレス / Email</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div class="form-group">
        <label for="subject">題名 / Subject</label>
        <input type="text" id="subject" name="subject" />
      </div>

      <div class="form-group">
        <label for="message">メッセージ / Your Message</label>
        <textarea id="message" name="message" rows="10" required></textarea>
      </div>

      <button type="submit" class="submit-button">送信</button>
    </form>
  </div>
</Layout>

<style>
  .contact-container {
    max-width: 800px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    letter-spacing: 0.1em;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.9rem;
    color: #333;
  }

  input, textarea {
    width: 100%;
    padding: 0.8rem;
    border: 1px solid #ddd;
    background-color: #f9f9f9;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.3s;
  }

  input:focus, textarea:focus {
    border-color: #666;
  }

  .submit-button {
    width: 120px;
    padding: 1rem;
    background-color: #4a4a4a;
    color: white;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s;
    margin-top: 1rem;
  }

  .submit-button:hover {
    background-color: #333;
  }

  textarea {
    resize: vertical;
  }
</style>