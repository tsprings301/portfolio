---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// 画像のインポート
import work1 from '../assets/my-work-oil_001.JPEG';
import work2 from '../assets/my-work-oil_002.jpg';
import work3 from '../assets/my-work-oil_003.jpg';
import work4 from '../assets/my-work-oil_004.JPG';

const slides = [
  { src: work1, alt: "Work 01" },
  { src: work2, alt: "Work 02" },
  { src: work3, alt: "Work 03" },
  { src: work4, alt: "Work 04" },
];
---

<Layout title="Haru Torisawa Portfolio">
  <div class="swiper">
    <div class="swiper-wrapper">
      {slides.map((slide) => (
        <div class="swiper-slide">
          <Image src={slide.src} alt={slide.alt} width={1600} />
        </div>
      ))}
    </div>
    <!-- 必要であればページ送りボタンやドットを表示できます（今回はシンプルに画像のみ） -->
    <div class="swiper-pagination"></div>
  </div>
</Layout>

<script>
  import Swiper from 'swiper';
  import { Pagination, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';
  import 'swiper/css/effect-fade';

  const swiper = new Swiper('.swiper', {
    modules: [Pagination, Autoplay, EffectFade],
    loop: true,
    effect: 'fade',
    fadeEffect: {
      crossFade: true // 前のスライドを完全に消してから次のスライドを表示する
    },
    speed: 1000,
    autoplay: {
      delay: 4000,
      disableOnInteraction: false,
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
  });
</script>

<style>
  .swiper {
    width: 100%;
    /* 高さを少し抑えて、下にドット用のスペースを確保する */
    height: calc(100vh - 250px); 
    margin-top: 2rem;
    /* スライダーの下側に余白を作る */
    margin-bottom: 50px; 
    overflow: visible; /* ドットを外側に表示させるために必要 */
  }

  .swiper-slide {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #fff; /* 重なり防止のため背景を白に固定 */
  }

  .swiper-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* --- ドット（ページネーション）の位置調整 --- */
  
  :global(.swiper-pagination) {
    /* 画像の下端からの距離。プラスの数値で画像の外側へ移動 */
    bottom: -40px !important; 
  }

  :global(.swiper-pagination-bullet) {
    width: 10px;
    height: 10px;
    background: #ccc;
    opacity: 1;
    transition: all 0.3s ease;
  }

  :global(.swiper-pagination-bullet-active) {
    background: #333 !important;
    width: 25px;
    border-radius: 5px;
  }
</style>