---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// 画像をインポート（拡張子を正確に記述してください）
import work1 from '../assets/my-work-oil_001.JPEG';
import work2 from '../assets/my-work-oil_002.jpg';
import work3 from '../assets/my-work-oil_003.jpg';
import work4 from '../assets/my-work-oil_004.JPG';

const works = [
  { src: work1, title: "『無題』", href: "/works/work-01" },
  { src: work2, title: "『敵を倒せ！』", href: "/works/work-02" },
  { src: work3, title: "『でっかいカニ』", href: "/works/work-03" },
  { src: work4, title: "『すべての音』", href: "/works/work-04" },
];
---

<Layout title="WORKS | Haru Torisawa">
  <div class="works-container">
    <h1>WORKS</h1>
    <div class="works-grid">
      {works.map((work) => (
        <a href={work.href} class="work-item">
          <Image src={work.src} alt={work.title} width={800} />
          <p>{work.title}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .works-container {
    padding-top: 2rem;
  }
  h1 {
    font-size: 1.5rem;
    margin-bottom: 3rem;
    letter-spacing: 0.1em;
  }
  .works-grid {
    display: grid;
    /* 画面幅に合わせて自動で列数を調整（最低300px） */
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 3rem;
  }
  .work-item {
    display: block;
    transition: opacity 0.3s ease;
  }
  .work-item:hover {
    opacity: 0.7;
  }
  .work-item p {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: #666;
  }
  img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>