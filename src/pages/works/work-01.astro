---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// 画像のインポート
import mainImg from '../../assets/my-work-oil_001.JPEG';
import cu4 from '../../assets/my-work-oil-cu_004.jpg';

const closeups = [cu4];
---

<Layout title="無題 | WORKS | Haru Torisawa">
  <article class="work-detail">
    <!-- 作品メイン画像 -->
    <div class="image-container">
      <Image src={mainImg} alt="無題" class="main-image" />
    </div>

    <!-- 作品情報セクション -->
    <div class="info-container">
      <header class="work-header">
        <h1>『無題』</h1>
        <p class="year">2024年</p>
      </header>

      <section class="spec">
        <p>素材：キャンバスに油彩</p>
        <p>サイズ：F30（910×727mm）</p>
      </section>

      <section class="description">
        <p></p>
      </section>

      <!-- クローズアップ画像セクション -->
      <section class="details-section">
        <h2>Details</h2>
        <div class="closeup-grid">
          {closeups.map((img, index) => (
            <div class="closeup-item">
              <Image src={img} alt={`Closeup ${index + 4}`} />
            </div>
          ))}
        </div>
      </section>

      <div class="back-link">
        <a href="/works">← WORKS</a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .work-detail {
    padding: 2rem 1rem;
    max-width: 900px;
    margin: 0 auto;
    box-sizing: border-box;
  }
  .image-container {
    margin-bottom: 3rem;
    text-align: center;
  }
  .main-image {
    width: 100%;
    height: auto;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  .work-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }
  .year {
    color: #888;
    margin-bottom: 1.5rem;
  }
  .spec {
    margin-bottom: 2rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #444;
  }
  .description {
    margin-bottom: 4rem;
    line-height: 1.8;
  }
  .details-section h2 {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
  }
  .closeup-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 4rem;
  }
  .closeup-item img {
    width: 100%;
    height: auto;
  }
  .back-link a {
    color: #666;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link a:hover {
    text-decoration: underline;
  }
</style>