---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Haru Torisawa Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="header">
			<div class="header-container">
				<!-- 左側：ロゴ（クリックでトップへ） -->
				<a href="/" class="logo">Haru Torisawa</a>

				<!-- 右側：ナビゲーション -->
				<nav class="nav">
					<ul class="nav-list">
						<li><a href="/works">WORKS</a></li>
						<li><a href="/about">ABOUT</a></li>
						<li><a href="/contact">CONTACT</a></li>
					</ul>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--text-color: #333;
	}
	html {
		font-family: sans-serif;
		background: #fff;
		color: var(--text-color);
	}
	body {
		margin: 0;
		padding: 0;
	}
	a {
		text-decoration: none;
		color: inherit;
	}

	/* ヘッダー全体のスタイル */
	.header {
		padding: 2rem 4rem; /* 上下左右の余白を広めにとる */
	}

	.header-container {
		display: flex;
		justify-content: space-between; /* 左右に振り分け */
		align-items: baseline; /* 文字の底辺を揃える */
	}

	.logo {
		font-size: 2rem;
		font-weight: bold;
		letter-spacing: 0.05em;
	}

	.nav-list {
		display: flex;
		gap: 2rem; /* メニュー間の余白 */
		list-style: none;
		margin: 0;
		padding: 0;
		font-size: 1.2rem;
		font-weight: 500;
	}

	/* メインコンテンツの余白 */
	main {
		padding: 0 4rem;
		max-width: 1200px;
		margin: 0 auto;
	}

    /* レスポンシブ対応：スマホでは縦に並べる */
    @media (max-width: 768px) {
        .header {
            padding: 1.5rem;
        }
        .header-container {
            flex-direction: column;
            gap: 1rem;
        }
        .nav-list {
            gap: 1rem;
        }
        main {
            padding: 0 1.5rem;
        }
    }
</style>